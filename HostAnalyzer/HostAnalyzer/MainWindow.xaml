<Window x:Class="HostAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Host 패킷 분석 (WCS / GCP)" Height="780" Width="920"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 입력 영역 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnOpenFile" Content="파일 열기" Width="90" Height="28" Click="BtnOpenFile_Click"/>
            <TextBlock Text="또는 아래에 Host 로그 붙여넣기 후" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <Button x:Name="BtnParsePaste" Content="붙여넣기 분석" Width="100" Height="28" Click="BtnParsePaste_Click"/>
        </StackPanel>

        <TextBox x:Name="TxtInput" Grid.Row="1" Height="120" Margin="0,0,0,8"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 ToolTip="Host 로그 파일 내용을 붙여넣거나, 파일 열기로 불러오세요. (WCS: / GCP: 형식)"/>

        <!-- WCS(RX) / GCP(TX) 표시 + 상세 -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#E8F4FD" Padding="6,4" CornerRadius="2" ToolTip="호스트(WCS)가 GCP로 보낸 요청 = GCP가 수신한 패킷 (WCSFROM)">
                <StackPanel>
                    <TextBlock x:Name="LblRx" Text="WCS → GCP (수신)" FontWeight="Bold" Foreground="#0066CC"/>
                    <TextBlock Text="호스트가 보낸 요청 · WCSFROM" FontSize="10" Foreground="#666"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="#E8FDF4" Padding="6,4" CornerRadius="2" ToolTip="GCP가 호스트(WCS)로 보낸 응답 = 호스트가 수신한 패킷 (WCSTO)">
                <StackPanel>
                    <TextBlock x:Name="LblTx" Text="GCP → WCS (송신)" FontWeight="Bold" Foreground="#00884A"/>
                    <TextBlock Text="GCP가 보낸 응답 · WCSTO" FontSize="10" Foreground="#666"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#B0D0E8" BorderThickness="1" CornerRadius="2" Padding="4">
                <TextBox x:Name="TxtRx" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12" Background="#FAFCFF"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#B0E8D0" BorderThickness="1" CornerRadius="2" Padding="4">
                <TextBox x:Name="TxtTx" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12" Background="#FAFFFC"/>
            </Border>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="수신 상세 (WCSFROM · D7000~D7025)" FontWeight="SemiBold" Foreground="#0066CC" Margin="0,6,0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="송신 상세 (WCSTO · D7500~D7625)" FontWeight="SemiBold" Foreground="#00884A" Margin="0,6,0,2"/>

            <!-- WCS 상세 -->
            <ScrollViewer Grid.Row="3" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,2,0">
                <Grid Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SYN (0x16×4)" Margin="0,2"/><TextBox x:Name="Rx_Syn" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="EQID" Margin="0,2"/><TextBox x:Name="Rx_EqId" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ReqType (0/1)" Margin="0,2"/><TextBox x:Name="Rx_ReqType" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Word 개수" Margin="0,2"/><TextBox x:Name="Rx_WordCount" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Data 해석" Margin="0,6,0,2" FontWeight="SemiBold"/><TextBox x:Name="Rx_DataInterpret" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="200" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
            <!-- GCP 상세 -->
            <ScrollViewer Grid.Row="3" Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="2,0,0,0">
                <Grid Margin="4,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SYN (0x16×4)" Margin="0,2"/><TextBox x:Name="Tx_Syn" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="EQID" Margin="0,2"/><TextBox x:Name="Tx_EqId" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ReqType (0x80/0x81)" Margin="0,2"/><TextBox x:Name="Tx_ReqType" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Word 개수" Margin="0,2"/><TextBox x:Name="Tx_WordCount" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Data 해석" Margin="0,6,0,2" FontWeight="SemiBold"/><TextBox x:Name="Tx_DataInterpret" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="200" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 하단: 이전/다음 & 인덱스 -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="8,6" CornerRadius="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnPrev" Content="◀ 이전 (PREV)" Width="110" Height="28" Click="BtnPrev_Click" Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtIndex" VerticalAlignment="Center" FontWeight="SemiBold" MinWidth="120" TextAlignment="Center"
                           Text="0 / 0 쌍"/>
                <Button x:Name="BtnNext" Content="다음 (NEXT) ▶" Width="110" Height="28" Click="BtnNext_Click" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
