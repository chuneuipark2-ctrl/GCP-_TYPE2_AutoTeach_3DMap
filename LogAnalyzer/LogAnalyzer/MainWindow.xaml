<Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SRM 로그 분석 (TX/RX)" Height="780" Width="920"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 입력 영역 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnOpenFile" Content="파일 열기" Width="90" Height="28" Click="BtnOpenFile_Click"/>
            <TextBlock Text="또는 아래에 로그 붙여넣기 후" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <Button x:Name="BtnParsePaste" Content="붙여넣기 분석" Width="100" Height="28" Click="BtnParsePaste_Click"/>
        </StackPanel>

        <TextBox x:Name="TxtInput" Grid.Row="1" Height="120" Margin="0,0,0,8"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 ToolTip="로그 파일 내용을 붙여넣거나, 파일 열기로 불러오세요."/>

        <!-- TX / RX 표시 + 상세 비트 -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#E8F4FD" Padding="6,4" CornerRadius="2">
                <TextBlock x:Name="LblTx" Text="TX (SEND)" FontWeight="Bold" Foreground="#0066CC"/>
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Background="#E8FDF4" Padding="6,4" CornerRadius="2">
                <TextBlock x:Name="LblRx" Text="RX (RECV)" FontWeight="Bold" Foreground="#00884A"/>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#B0D0E8" BorderThickness="1" CornerRadius="2" Padding="4">
                <TextBox x:Name="TxtTx" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12" Background="#FAFCFF"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#B0E8D0" BorderThickness="1" CornerRadius="2" Padding="4">
                <TextBox x:Name="TxtRx" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12" Background="#FAFFFC"/>
            </Border>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="TX 상세 (udpClientClass 필드)" FontWeight="SemiBold" Foreground="#0066CC" Margin="0,6,0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="RX 상세 (udpClientClass 필드)" FontWeight="SemiBold" Foreground="#00884A" Margin="0,6,0,2"/>

            <!-- TX 상세 에디트 (변수명/주석 참조) -->
            <ScrollViewer Grid.Row="3" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,2,0">
                <Grid Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SYN (0x16×4)" Margin="0,2"/><TextBox x:Name="Tx_Syn" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="srcType (SRC TYPE)" Margin="0,2"/><TextBox x:Name="Tx_SrcType" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="srcID (SRC INDEX)" Margin="0,2"/><TextBox x:Name="Tx_SrcId" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="dstType (DST TYPE)" Margin="0,2"/><TextBox x:Name="Tx_DstType" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="dstID (DST INDEX)" Margin="0,2"/><TextBox x:Name="Tx_DstId" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="seqNum (Sequence)" Margin="0,2"/><TextBox x:Name="Tx_SeqNum" Grid.Row="5" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="byPass1" Margin="0,2"/><TextBox x:Name="Tx_ByPass1" Grid.Row="6" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="byPass2" Margin="0,2"/><TextBox x:Name="Tx_ByPass2" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="cmd1 (CMD1)" Margin="0,2"/><TextBox x:Name="Tx_Cmd1" Grid.Row="8" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="len (DATA+1)" Margin="0,2"/><TextBox x:Name="Tx_Len" Grid.Row="9" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="cmd2 (CMD2)" Margin="0,2"/><TextBox x:Name="Tx_Cmd2" Grid.Row="10" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="data (Payload)" Margin="0,2"/><TextBox x:Name="Tx_Data" Grid.Row="11" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Data 해석" Margin="0,6,0,2" FontWeight="SemiBold"/><TextBox x:Name="Tx_DataInterpret" Grid.Row="12" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
            <!-- RX 상세 에디트 -->
            <ScrollViewer Grid.Row="3" Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="2,0,0,0">
                <Grid Margin="4,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SYN (0x16×4)" Margin="0,2"/><TextBox x:Name="Rx_Syn" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="srcType (SRC TYPE)" Margin="0,2"/><TextBox x:Name="Rx_SrcType" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="srcID (SRC INDEX)" Margin="0,2"/><TextBox x:Name="Rx_SrcId" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="dstType (DST TYPE)" Margin="0,2"/><TextBox x:Name="Rx_DstType" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="dstID (DST INDEX)" Margin="0,2"/><TextBox x:Name="Rx_DstId" Grid.Row="4" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="seqNum (Sequence)" Margin="0,2"/><TextBox x:Name="Rx_SeqNum" Grid.Row="5" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="byPass1" Margin="0,2"/><TextBox x:Name="Rx_ByPass1" Grid.Row="6" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="byPass2" Margin="0,2"/><TextBox x:Name="Rx_ByPass2" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="cmd1 (CMD1+0x80)" Margin="0,2"/><TextBox x:Name="Rx_Cmd1" Grid.Row="8" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="len (DATA+1)" Margin="0,2"/><TextBox x:Name="Rx_Len" Grid.Row="9" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="cmd2 (CMD2)" Margin="0,2"/><TextBox x:Name="Rx_Cmd2" Grid.Row="10" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Text="data (Payload)" Margin="0,2"/><TextBox x:Name="Rx_Data" Grid.Row="11" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="36"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Data 해석" Margin="0,6,0,2" FontWeight="SemiBold"/><TextBox x:Name="Rx_DataInterpret" Grid.Row="12" Grid.Column="1" IsReadOnly="True" Margin="0,2" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 하단: 이전/다음 & 인덱스 -->
        <Border Grid.Row="3" Background="#F0F0F0" Padding="8,6" CornerRadius="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnPrev" Content="◀ 이전 (PREV)" Width="110" Height="28" Click="BtnPrev_Click" Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtIndex" VerticalAlignment="Center" FontWeight="SemiBold" MinWidth="120" TextAlignment="Center"
                           Text="0 / 0 쌍"/>
                <Button x:Name="BtnNext" Content="다음 (NEXT) ▶" Width="110" Height="28" Click="BtnNext_Click" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
