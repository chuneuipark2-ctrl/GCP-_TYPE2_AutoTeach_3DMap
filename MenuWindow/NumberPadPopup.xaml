                </Style>
            </Button.Style>
        </Button>
        <Button x:Name="Btn_Back" Content="←" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#02000000" BorderBrush="#FFB8D8FC" FontWeight="Bold" Margin="5,5,5,5" FontSize="40" Click="NumberPadBackspace_Click" Grid.RowSpan="2">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
