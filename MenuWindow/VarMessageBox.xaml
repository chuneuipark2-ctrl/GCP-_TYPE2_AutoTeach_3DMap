<Window x:Class="gcp_Wpf.MenuWindow.VarMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gcp_Wpf.MenuWindow"
        xmlns:lx="clr-namespace:gcp_Wpf"
        mc:Ignorable="d"
        Title="VarMessageBox" Height="210" Width="480" MinWidth="300"
        Background="#1E232D"
        ShowInTaskbar="False" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Background="#1E232D" Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <TextBlock x:Name="lbl_infoText" Text=""
                       Foreground="White" FontSize="15" FontWeight="Bold"
                       TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Label x:Name="lbl_timeCnt" Content="" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,8,0"
                   Foreground="#ADADAD" FontSize="15" FontWeight="Bold"/>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="Btn_OK" Content="OK" Width="100" Height="38" Margin="8,0"
                    FontSize="14" FontWeight="Bold" Foreground="White"
                    Background="#2D5A96" BorderBrush="#64A0DC" BorderThickness="1"
                    Cursor="Hand" Click="Btn_OK_Click"/>
            <Button x:Name="Btn_Cancel" Content="Cancel" Width="100" Height="38" Margin="8,0"
                    FontSize="14" FontWeight="Bold" Foreground="White"
                    Background="#2D5A96" BorderBrush="#64A0DC" BorderThickness="1"
                    Cursor="Hand" Click="Btn_Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
    
