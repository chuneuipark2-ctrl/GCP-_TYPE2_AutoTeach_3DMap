<Page x:Class="gcp_Wpf.PageAlarmLog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageAlarmLog">
    <Grid>
        <TabControl Background="{x:Null}">
            <TabControl.Resources>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Background" Value="#00808080"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#00000000"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>
            <TabItem Header="{lx:Loc 이상내역}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="10*"/>
                        <RowDefinition Height="349*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="AlarmList" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0" Background="#19000000">
                        <DataGrid.Style>
                            <Style TargetType="{x:Type DataGrid}">
                                <Setter Property="Background" Value="#19D3D3D3"/>
                                <Setter Property="BorderBrush" Value="#00808080"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="#19808080"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="#19FFFFFF"/>
                                <Setter Property="Foreground" Value="#CCADD8E6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding Path=errNum}" Width="30" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 발생일시}" Binding="{Binding Path=occurredTime}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 에러코드}" Binding="{Binding Path=errCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 서브코드}" Binding="{Binding Path=subCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 이상내역}" Binding="{Binding Path=errContent}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="{lx:Loc 에러코드}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="10*"/>
                        <RowDefinition Height="349*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="AlarmCodeList" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0" Background="#19000000">
                        <DataGrid.Style>
                            <Style TargetType="{x:Type DataGrid}">
                                <Setter Property="Background" Value="#19D3D3D3"/>
                                <Setter Property="BorderBrush" Value="#00808080"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="#19808080"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="#19FFFFFF"/>
                                <Setter Property="Foreground" Value="#CCADD8E6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{lx:Loc 메인코드}" Binding="{Binding Path=errCode}" Width="130" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 에러내용}" Binding="{Binding Path=errContent}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="{lx:Loc 에러리스트}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="10*"/>
                        <RowDefinition Height="349*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="AlarmSubCodeList" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0" Background="#19000000">
                        <DataGrid.Style>
                            <Style TargetType="{x:Type DataGrid}">
                                <Setter Property="Background" Value="#19D3D3D3"/>
                                <Setter Property="BorderBrush" Value="#00808080"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="#19808080"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="#19FFFFFF"/>
                                <Setter Property="Foreground" Value="#CCADD8E6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{lx:Loc 메인코드}" Binding="{Binding Path=errCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 서브코드}" Binding="{Binding Path=subCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 에러내용}" Binding="{Binding Path=errContent}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="{lx:Loc 경고리스트}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="10*"/>
                        <RowDefinition Height="349*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="AlarmWarningCodeList" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0" Background="#19000000">
                        <DataGrid.Style>
                            <Style TargetType="{x:Type DataGrid}">
                                <Setter Property="Background" Value="#19D3D3D3"/>
                                <Setter Property="BorderBrush" Value="#00808080"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="#19808080"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="#19FFFFFF"/>
                                <Setter Property="Foreground" Value="#CCADD8E6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{lx:Loc 메인코드}" Binding="{Binding Path=errCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 서브코드}" Binding="{Binding Path=subCode}" Width="82" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lx:Loc 경고내용}" Binding="{Binding Path=errContent}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        <Button Margin="288,0,414,422" Click="Button_Click" Height="30" Width="100" Content="{lx:Loc 알람 테스트}" Visibility="Collapsed"></Button>
    </Grid>
</Page>
