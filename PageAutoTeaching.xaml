<Page x:Class="gcp_Wpf.PageAutoTeaching"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      mc:Ignorable="d"
      d:DesignHeight="514" d:DesignWidth="800"
      Title="PageAutoTeaching">

    <Page.Resources>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,4,4,4"/>
            <Setter Property="BorderBrush" Value="#FFB8D8FC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF22B9AF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF1A9A8A"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#FFB44545"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF993333"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EditStyle" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFB8D8FC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Margin" Value="3,2,3,2"/>
        </Style>
        <Style x:Key="LblStyle" TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,2">
            <Grid Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="AUTO TEACHING" Foreground="White" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="16" Margin="5,0,0,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse x:Name="ellStatus" Width="14" Height="14" Fill="#FFADADAD" Margin="0,0,6,0"/>
                    <Label x:Name="lbl_status" Content="IDLE" Foreground="White" FontWeight="Bold" FontSize="13" VerticalContentAlignment="Center"/>
                    <Button x:Name="btn_Close" Content="CLOSE" Click="Btn_Close_Click" Height="26" Padding="10,0" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="#02000000"/><Setter Property="Foreground" Value="#FFB8D8FC"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="DarkBlue"/></Trigger></Style.Triggers></Style></Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================== CONTENT: 4 overlaid panels (Setup/Run/Review/MmMove) ======================== -->
        <Grid Grid.Row="1">

        <!-- ==================== pnl_Setup (Visible) ==================== -->
        <Grid x:Name="pnl_Setup" Visibility="Visible" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                    <!-- Settings -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/><ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/><ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <!-- START 전 대상 셀 수 + CARGO 경고 (실시간) -->
                        <Label x:Name="lbl_targetCount" Content="" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Foreground="#FF22B9AF" FontWeight="Bold" FontSize="12"/>
                        <Label Content="Camera" Style="{StaticResource LblStyle}" Grid.Row="0" Grid.Column="4"/>
                        <!-- Row가 카메라를 자동 결정(수동 선택 제거) — 읽기전용 표시 -->
                        <Label x:Name="lbl_camAuto" Content="camera3" Grid.Row="0" Grid.Column="5" Foreground="#FFB8D8FC" Style="{StaticResource LblStyle}" ToolTip="Row에 따라 자동 선택 (Row1=camera3, Row2=camera1). 수동 선택 불가."/>
                        <Label x:Name="lbl_camStatus" Content="--" Grid.Row="0" Grid.Column="6" Foreground="#FFADADAD" Style="{StaticResource LblStyle}"/>

                        <Label Content="ROW" Style="{StaticResource LblStyle}" Grid.Row="1" Grid.Column="0"/>
                        <ComboBox x:Name="combo_Row" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Height="24" Margin="3,0,3,0" SelectionChanged="Combo_Row_SelectionChanged"/>
                        <Label Content="BAY" Style="{StaticResource LblStyle}" Grid.Row="1" Grid.Column="2"/>
                        <TextBox x:Name="edit_BayRange" Text="1-MAX" Style="{StaticResource EditStyle}" Grid.Row="1" Grid.Column="3" TextChanged="Range_Changed"/>
                        <Label Content="LEVEL" Style="{StaticResource LblStyle}" Grid.Row="1" Grid.Column="4"/>
                        <TextBox x:Name="edit_LevRange" Text="1-MAX" Style="{StaticResource EditStyle}" Grid.Row="1" Grid.Column="5" TextChanged="Range_Changed"/>
                        <CheckBox x:Name="chk_HasCargo" Content="CARGO" Grid.Row="1" Grid.Column="6" Foreground="White" VerticalContentAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Checked="Cargo_Changed" Unchecked="Cargo_Changed"/>
                    </Grid>

                    <!-- Log (pnl_Setup body) -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 미니 툴바: 로그 폴더 열기 / 화면 로그 클리어 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                            <Button x:Name="btn_OpenLog" Content="📁 LOG FOLDER" Click="Btn_OpenLog_Click" Height="22" Padding="6,0" FontSize="10" Margin="0,0,3,0" ToolTip="SRM{N}/Teaching/Log 폴더 열기" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151"/>
                            <Button x:Name="btn_ClearLog" Content="✕ CLEAR" Click="Btn_ClearLog_Click" Height="22" Padding="6,0" FontSize="10" ToolTip="화면 로그만 지우기 (파일 로그 유지)" Background="#33000000" Foreground="#FFADADAD" BorderBrush="#FF555151"/>
                        </StackPanel>
                        <ListBox x:Name="listBox_Log" Grid.Row="1" Background="#19000000" Foreground="#CCADD8E6" BorderBrush="#FF555151" FontSize="11">
                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#CCADD8E6"/></Style></ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>

                    <!-- pnl_Setup 하단 버튼: 라이다 / MM 이동(정비) / CALIB / START -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Label Content="프레임" Style="{StaticResource LblStyle}" VerticalContentAlignment="Center" Margin="4,0,2,0"/>
                        <TextBox x:Name="edit_LidarFrames" Style="{StaticResource EditStyle}" Width="48" Height="30" VerticalContentAlignment="Center" Margin="0,0,4,0" ToolTip="비우면 기본 20프레임, 지정 시 5~100 (범위 밖은 자동 보정)"/>
                        <Button x:Name="btn_Lidar" Content="라이다 스캔" Click="Btn_Lidar_Click" Height="38" MinWidth="110" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151" FontWeight="Bold" FontSize="13" Margin="4" ToolTip="POST /api/gc/cmd/lidar/scan_start — body 없이 전송(서버 기본 20프레임), 응답 원문을 로그에 출력. 측정값은 서버에 120초만 유효(승강 추론 선행용) — 티칭 런은 셀마다 자동 재스캔"/>
                        <Button x:Name="btn_LidarBaseline" Content="기준설정" Click="Btn_LidarBaseline_Click" Height="38" MinWidth="100" Background="#FFB8860B" Foreground="#FFB8D8FC" BorderBrush="#FF555151" FontWeight="Bold" FontSize="13" Margin="4" ToolTip="라이다 baseline 설정 — 최초 설치/기구 재배치 후 1회. 크레인 정지 상태에서 현재 프레임을 기준으로 등록(POST :9000/api/lidar/baseline). 미설정 시 승강 추론이 lidar_missing으로 실패"/>
                        <Button x:Name="btnSetup_Mm" Content="MM 이동(정비)" Click="Btn_Mm_Click" Height="38" MinWidth="120" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151" FontWeight="Bold" FontSize="13" Margin="4"/>
                        <Button x:Name="btn_Calib" Content="CALIB" Click="Btn_Calib_Click" Height="38" MinWidth="100">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="#FF6A1B9A"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF4A148C"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button x:Name="btn_Start" Content="START" Click="Btn_Start_Click" Style="{StaticResource BtnStyle}" Height="38" MinWidth="140"/>
                    </StackPanel>
        </Grid>
        <!-- ==================== /pnl_Setup ==================== -->

        <!-- ==================== pnl_Run (Collapsed) — M3 polished progress screen ==================== -->
        <Grid x:Name="pnl_Run" Visibility="Collapsed" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 진행 본문: 좌(현재 셀 + 스냅샷 + 스텝) / 우(진행률 + ETA + 카운트 + 최근) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55*"/>
                    <ColumnDefinition Width="45*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측: 현재 셀 / 스냅샷 / 스텝 -->
                <Grid Grid.Column="0" Margin="0,0,3,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="lblRun_Cell" Grid.Row="0" Content="현재 셀 —" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="14"/>
                    <Border Grid.Row="1" Background="#19000000" BorderBrush="#FF555151" BorderThickness="1" CornerRadius="3" Margin="0,2,0,2">
                        <Image x:Name="imgRun_Snap" Stretch="Uniform" Margin="2"/>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <Border x:Name="stepMove" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="이동" Foreground="#FFADADAD" FontSize="11"/></Border>
                        <Border x:Name="stepArrive" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="도착" Foreground="#FFADADAD" FontSize="11"/></Border>
                        <Border x:Name="stepShoot" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="촬영" Foreground="#FFADADAD" FontSize="11"/></Border>
                        <Border x:Name="stepAnalyze" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="분석" Foreground="#FFADADAD" FontSize="11"/></Border>
                        <Border x:Name="stepLidar" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="라이다" Foreground="#FFADADAD" FontSize="11"/></Border>
                        <Border x:Name="stepZ" Background="#33000000" CornerRadius="6" Padding="8,3" Margin="2"><Label Content="승강" Foreground="#FFADADAD" FontSize="11"/></Border>
                    </StackPanel>
                </Grid>

                <!-- 우측: 진행률 / ETA / 카운트 / 최근 처리 -->
                <Grid Grid.Column="1" Margin="3,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <Label Content="전체 진행률" Foreground="#FFADADAD" FontSize="12"/>
                        <Label x:Name="lblRun_Progress" Content="0 / 0" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="20"/>
                        <ProgressBar x:Name="progRun" Height="6" Minimum="0" Maximum="100" Value="0" Foreground="#FF22B9AF" Background="#33000000"/>
                        <Label x:Name="lblRun_Eta" Content="예상 남은 시간 —" Foreground="#FFADADAD" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <StackPanel Margin="0,0,16,0"><Label x:Name="lblRun_Ok" Content="0" Foreground="LightGreen" FontWeight="Bold" FontSize="20"/><Label Content="정상" Foreground="#FFADADAD" FontSize="11"/></StackPanel>
                        <StackPanel Margin="0,0,16,0"><Label x:Name="lblRun_Fail" Content="0" Foreground="#FFE57373" FontWeight="Bold" FontSize="20"/><Label Content="실패" Foreground="#FFADADAD" FontSize="11"/></StackPanel>
                        <StackPanel Margin="0,0,14,0"><Label x:Name="lblRun_curTrav" Content="-" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="20"/><Label Content="주행 mm" Foreground="#FFADADAD" FontSize="11"/></StackPanel>
                        <StackPanel><Label x:Name="lblRun_curLift" Content="-" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="20"/><Label Content="승강 mm" Foreground="#FFADADAD" FontSize="11"/></StackPanel>
                    </StackPanel>
                    <Label Grid.Row="2" Content="최근 처리" Foreground="#FFADADAD" FontSize="12" Margin="0,8,0,2"/>
                    <ListBox x:Name="lstRun_Recent" Grid.Row="3" Background="#19000000" Foreground="#CCADD8E6" BorderBrush="#FF555151" FontSize="11">
                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#CCADD8E6"/></Style></ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>

                <!-- 진단(숨김): 기존 UpdateProgress/루프가 갱신하는 옛 라벨 보존 — NRE 방지용, 화면엔 안 보임 -->
                <StackPanel x:Name="pnl_RunDiag" Visibility="Collapsed">
                    <Label x:Name="lbl_curTarget" Content="-"/>
                    <Label x:Name="lbl_curTrav" Content="0"/>
                    <Label x:Name="lbl_curLift" Content="0"/>
                    <Label x:Name="lbl_curFork" Content="CENTER"/>
                    <Label x:Name="lbl_progress" Content="0 / 0"/>
                    <Label x:Name="lbl_result" Content="-" Foreground="LightGreen"/>
                    <ProgressBar x:Name="progressBar" Minimum="0" Maximum="100" Value="0"/>
                </StackPanel>
            </Grid>

            <!-- pnl_Run 하단 버튼: 일시정지 / SKIP / STOP / 결과 확인·반영하기 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button x:Name="btnRun_Pause" Content="⏸ 일시정지" Click="Btn_Pause_Click" Height="38" MinWidth="120" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151" FontWeight="Bold" FontSize="13" Margin="4"/>
                <Button x:Name="btn_Skip" Content="SKIP" Click="Btn_Skip_Click" IsEnabled="False" Height="38" MinWidth="100">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="#FF8B6914"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF6B5010"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger></Style.Triggers></Style></Button.Style>
                </Button>
                <Button x:Name="btn_Stop" Content="STOP" Click="Btn_Stop_Click" Style="{StaticResource BtnRed}" IsEnabled="False" Height="38" MinWidth="100"/>
                <Button x:Name="btnRun_Review" Content="결과 확인·반영하기" Click="Btn_Review_Click" IsEnabled="False" Style="{StaticResource BtnStyle}" Height="38" MinWidth="160"/>
            </StackPanel>
        </Grid>
        <!-- ==================== /pnl_Run ==================== -->

        <!-- ==================== pnl_Review (Collapsed) — RESULT REVIEW moved as-is; M4 polishes ==================== -->
        <Grid x:Name="pnl_Review" Visibility="Collapsed" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55*"/>
                    <ColumnDefinition Width="45*"/>
                </Grid.ColumnDefinitions>
                <!-- 좌: 결과 표 -->
                <DataGrid x:Name="grid_Review" Grid.Column="0" Margin="0,0,3,0" AutoGenerateColumns="False"
                          IsReadOnly="False" Background="#19000000" Foreground="#CCADD8E6" BorderBrush="#FF555151"
                          HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                          SelectionChanged="Grid_Review_SelectionChanged" CellEditEnding="Grid_Review_CellEditEnding">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Success}" Value="False">
                                    <Setter Property="Foreground" Value="#FFFF6B6B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="셀" Binding="{Binding Cell}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="0.5*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="주행측정" Binding="{Binding Measured}" Width="0.7*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="주행편차" Binding="{Binding Deviation}" Width="0.6*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="승강측정" Binding="{Binding LiftMeasured}" Width="0.7*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="승강편차" Binding="{Binding LiftDeviation}" Width="0.6*" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="반영" Binding="{Binding Apply}" Width="0.5*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- 우: 상세 + 이미지 + 버튼 -->
                <Grid Grid.Column="1" Margin="3,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TabControl x:Name="tab_ReviewImg" Grid.Row="1" Background="#19000000" BorderBrush="#FF555151">
                        <TabItem Header="원본"><Image x:Name="img_Raw" Stretch="Uniform"/></TabItem>
                        <TabItem Header="보정"><Image x:Name="img_Cal" Stretch="Uniform"/></TabItem>
                    </TabControl>
                    <!-- 선택 셀 상세: 확인필요 뱃지(우측) + 승강/주행 before→after -->
                    <DockPanel Grid.Row="0">
                        <Label x:Name="lblRev_Badge" DockPanel.Dock="Right" Content="" Foreground="#FFFFC107" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel>
                            <Label x:Name="lblRev_TravBA" Content="주행 위치   —" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="13"/>
                            <Label x:Name="lblRev_LiftBA" Content="승강 위치   —" Foreground="#FFB8D8FC" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </DockPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Label x:Name="lblRev_SelInfo" Content="" Foreground="#FF9FB6C6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="btn_SelectNormal" Content="정상 셀 일괄 선택" Click="Btn_SelectNormal_Click" Margin="0,0,4,0" Padding="8,2" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button x:Name="btn_RejectCell" Content="이 셀 반려" Click="Btn_RejectCell_Click" Margin="0,0,4,0" Padding="10,4" Background="#33000000" Foreground="#FFADADAD" BorderBrush="#FF555151"/>
                        <Button x:Name="btnRev_ApplyOne" Content="이 셀 반영" Click="Btn_ApplyOne_Click" Margin="0,0,4,0" Padding="10,4" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151"/>
                        <Button x:Name="btn_ApplySelected" Content="선택 셀 반영" Click="Btn_ApplySelected_Click" Padding="10,4" Background="#FF2E7D32" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- pnl_Review 하단 버튼: SAVE / VERIFY / EXCEL -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button x:Name="btn_Excel" Content="EXCEL" Click="Btn_Excel_Click" Height="38" MinWidth="100">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="#FF2E7D32"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF1B5E20"/></Trigger></Style.Triggers></Style></Button.Style>
                </Button>
                <Button x:Name="btn_Verify" Content="VERIFY" Click="Btn_Verify_Click" Height="38" MinWidth="100" ToolTip="3단계 검증(재추론): 2단계 결과 위치로 순차 이동하며 다시 추론해 잔차 확인 (0x59 사용)">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="#FF00838F"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF006064"/></Trigger></Style.Triggers></Style></Button.Style>
                </Button>
                <Button x:Name="btn_Save" Content="SAVE" Click="Btn_Save_Click" IsEnabled="False" Height="38" MinWidth="100">
                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource BtnStyle}"><Setter Property="Background" Value="LightBlue"/><Setter Property="Foreground" Value="Black"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="LightCoral"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger></Style.Triggers></Style></Button.Style>
                </Button>
            </StackPanel>
        </Grid>
        <!-- ==================== /pnl_Review ==================== -->

        <!-- ==================== pnl_MmMove (Collapsed) — MM POSITION MOVE moved as-is ==================== -->
        <Grid x:Name="pnl_MmMove" Visibility="Collapsed">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 뒤로 가기 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                        <Button x:Name="btnMm_Back" Content="◀ 뒤로" Click="Btn_MmBack_Click" Height="26" Padding="10,0" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>

                    <!-- mm 이동 입력 -->
                    <Grid Grid.Row="1" Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/><ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="TRAV (mm)" Style="{StaticResource LblStyle}" Grid.Column="0"/>
                        <TextBox x:Name="edit_mmTrav" Text="0" Style="{StaticResource EditStyle}" Grid.Column="1" FontSize="16" Height="34"/>
                        <Label Content="LIFT (mm)" Style="{StaticResource LblStyle}" Grid.Column="2"/>
                        <TextBox x:Name="edit_mmLift" Text="0" Style="{StaticResource EditStyle}" Grid.Column="3" FontSize="16" Height="34"/>
                        <Label Content="STOP(mm)" Style="{StaticResource LblStyle}" Grid.Column="4" FontSize="10" ToolTip="관성 조기정지 거리 (목표 N mm 전에 정지 → 펄스 보정)"/>
                        <TextBox x:Name="edit_mmRow" Text="70" Style="{StaticResource EditStyle}" Grid.Column="5" FontSize="14" Height="34"/>
                    </Grid>

                    <!-- SoftLimit 편집 영역 (Vexi 0xA4/0xA6 영구저장) -->
                    <Border Grid.Row="2" BorderBrush="#FFFFA500" BorderThickness="1" CornerRadius="3" Margin="0,0,0,5" Padding="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <!-- 첫 줄: Drive SoftLimit -->
                            <Label Grid.Row="0" Grid.Column="0" Content="SL Drive Home" Style="{StaticResource LblStyle}" FontSize="10" Foreground="#FFFFA500"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="edit_slDriveHome" Text="0" Style="{StaticResource EditStyle}" FontSize="12" Height="24"/>
                            <Label Grid.Row="0" Grid.Column="2" Content="End" Style="{StaticResource LblStyle}" FontSize="10" Foreground="#FFFFA500"/>
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="edit_slDriveEnd" Text="0" Style="{StaticResource EditStyle}" FontSize="12" Height="24"/>
                            <Button Grid.Row="0" Grid.Column="4" x:Name="btn_slRead" Content="READ SL" Click="Btn_SlRead_Click" Style="{StaticResource BtnStyle}" Height="24" FontSize="11" Margin="2"/>
                            <Button Grid.Row="0" Grid.Column="5" x:Name="btn_slSave" Content="SAVE SL" Click="Btn_SlSave_Click" Height="24" FontSize="11" Margin="2" ToolTip="0xA4/0xA6로 SRM에 영구 저장 (위험)">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                                        <Setter Property="Background" Value="#FFFFA500"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FFFF8800"/></Trigger>
                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- 두번째 줄: Lift SoftLimit -->
                            <Label Grid.Row="1" Grid.Column="0" Content="SL Lift Home" Style="{StaticResource LblStyle}" FontSize="10" Foreground="#FFFFA500"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="edit_slLiftHome" Text="0" Style="{StaticResource EditStyle}" FontSize="12" Height="24"/>
                            <Label Grid.Row="1" Grid.Column="2" Content="End" Style="{StaticResource LblStyle}" FontSize="10" Foreground="#FFFFA500"/>
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="edit_slLiftEnd" Text="0" Style="{StaticResource EditStyle}" FontSize="12" Height="24"/>
                            <Label Grid.Row="1" Grid.Column="4" Content="⚠ 영구저장" Foreground="#FFFFA500" FontSize="9" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            <Button Grid.Row="1" Grid.Column="5" x:Name="btn_calRestore" Content="CAL 복구" Click="Btn_CalRestore_Click" Height="24" FontSize="10" Margin="2" ToolTip="캘리브레이션 도중 crash 시 cellLev[0]/cellLev[끝]을 원본으로 0x95 복구 (INI Pending=1 일 때만)">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BtnStyle}">
                                        <Setter Property="Background" Value="#FF6A1B9A"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#FF4A148C"/></Trigger>
                                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#33000000"/><Setter Property="Foreground" Value="#7FC8C8C8"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 버튼 -->
                    <Grid Grid.Row="3" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btn_mmMove" Content="MOVE" Grid.Column="0" Click="Btn_MmMove_Click" Style="{StaticResource BtnStyle}" Height="38"/>
                        <Button x:Name="btn_mmStop2" Content="STOP" Grid.Column="1" Click="Btn_MmStop_Click" Style="{StaticResource BtnRed}" Height="38" IsEnabled="False"/>
                        <Button x:Name="btn_mmReadPos" Content="READ POS" Grid.Column="2" Click="Btn_MmReadPos_Click" Style="{StaticResource BtnStyle}" Height="38"/>
                        <Button x:Name="btn_probe59" Content="PROBE" Grid.Column="3" Click="Btn_Probe59_Click" Style="{StaticResource BtnStyle}" Height="38" ToolTip="0x59 프로토콜 탐색"/>
                        <Border Grid.Column="4" BorderBrush="#FF555151" BorderThickness="1" CornerRadius="3" Margin="5,2,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="TRAV:" Style="{StaticResource LblStyle}" Grid.Column="0" FontSize="10"/>
                                <Label x:Name="lbl_mmBayId" Content="-" Grid.Column="1" Foreground="#FFB8D8FC" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                <Label Content="LIFT:" Style="{StaticResource LblStyle}" Grid.Column="2" FontSize="10"/>
                                <Label x:Name="lbl_mmLevId" Content="-" Grid.Column="3" Foreground="#FFB8D8FC" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="12"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 로그 -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 미니 툴바 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                            <Button x:Name="btn_OpenMmLog" Content="📁 MM LOG FOLDER" Click="Btn_OpenMmLog_Click" Height="22" Padding="6,0" FontSize="10" Margin="0,0,3,0" ToolTip="SRM{N}/Teaching/MmLog 폴더 열기" Background="#33000000" Foreground="#FFB8D8FC" BorderBrush="#FF555151"/>
                            <Button x:Name="btn_ClearMmLog" Content="✕ CLEAR" Click="Btn_ClearMmLog_Click" Height="22" Padding="6,0" FontSize="10" ToolTip="화면 로그만 지우기 (파일 로그 유지)" Background="#33000000" Foreground="#FFADADAD" BorderBrush="#FF555151"/>
                        </StackPanel>
                        <ListBox x:Name="listBox_MmLog" Grid.Row="1" Background="#19000000" Foreground="#CCADD8E6" BorderBrush="#FF555151" FontSize="11">
                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#CCADD8E6"/></Style></ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Grid>
        </Grid>
        <!-- ==================== /pnl_MmMove ==================== -->

        </Grid>
        <!-- ======================== /CONTENT ======================== -->
    </Grid>
</Page>
