        </Border>
        <GridSplitter Grid.Row="7" HorizontalAlignment="Stretch" Height="2" Margin="0,0,0,0" VerticalAlignment="Top"/>
        <Grid Grid.Row="8">
            <Grid.RowDefinitions>
