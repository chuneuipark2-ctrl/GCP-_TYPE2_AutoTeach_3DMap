<Page x:Class="gcp_Wpf.PageCraneOperate"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageCraneOperate">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 상단 컨트롤 패널 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Margin="5" CornerRadius="5">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Label Grid.Column="0" Content="BAY:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="txt_BayCount" Grid.Column="1" Text="10" Width="50" Margin="5,0" 
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                
                <Label Grid.Column="2" Content="LEV:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="20,0,0,0"/>
                <TextBox x:Name="txt_LevCount" Grid.Column="3" Text="6" Width="50" Margin="5,0" 
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                
                <Button x:Name="btn_UpdateLayout" Grid.Column="4" Content="{lx:Loc 레이아웃 업데이트}" 
                        Background="#FF3498DB" Foreground="White" Padding="10,5" Margin="20,0,0,0"
                        BorderThickness="0" Click="btn_UpdateLayout_Click"/>
                
                <Label Grid.Column="5" Content="{lx:Loc 크레인 위치 - BAY:}" Foreground="White" VerticalAlignment="Center" 
                       FontWeight="Bold" Margin="30,0,0,0"/>
                <TextBox x:Name="txt_CraneBay" Grid.Column="6" Text="1" Width="50" Margin="5,0" 
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                
                <Label Grid.Column="7" Content="LEV:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0,0,0"/>
                <TextBox x:Name="txt_CraneLev" Grid.Column="8" Text="1" Width="50" Margin="5,0" 
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                
                <Button x:Name="btn_MoveCrane" Grid.Column="9" Content="{lx:Loc 크레인 이동}" 
                        Background="#FFE74C3C" Foreground="White" Padding="10,5" Margin="10,0,0,0"
                        BorderThickness="0" Click="btn_MoveCrane_Click"/>
            </Grid>
        </Border>
        
        <!-- WebView2 컨테이너 -->
        <Border Grid.Row="1" Background="White" Margin="5" CornerRadius="5" BorderBrush="#FFBDC3C7" BorderThickness="1">
            <wv2:WebView2 x:Name="webView"/>
        </Border>
    </Grid>
</Page>