<Page x:Class="gcp_Wpf.PageDIO"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      Title="PageDIO">
  <FrameworkElement.Resources>
    <Style x:Key="ButtonStyle_DIO" TargetType="{x:Type Button}">
      <Setter Property="Control.Foreground" Value="#FFB8D8FC"/>
      <Setter Property="Control.FontWeight" Value="Bold"/>
      <Setter Property="Control.Background" Value="#02000000"/>
      <Setter Property="Control.BorderBrush" Value="#FFB8D8FC"/>
      <Setter Property="FrameworkElement.Margin" Value="5"/>
      <Setter Property="FrameworkElement.HorizontalAlignment" Value="Stretch"/>
      <Setter Property="FrameworkElement.VerticalAlignment" Value="Stretch"/>
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Control.Background}"
                    BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="ButtonBase.IsPressed" Value="True">
          <Setter Property="Control.Background" Value="#7FFFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ToggleButtonStyle_DI" TargetType="{x:Type ToggleButton}">
      <Setter Property="Control.Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ToggleButton}">
            <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}"
                    Padding="{TemplateBinding Control.Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="Control.Background" Value="#02000000"/>
      <Setter Property="Control.BorderBrush" Value="#FFB8D8FC"/>
      <Setter Property="Control.FontWeight" Value="Bold"/>
      <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
      <Style.Triggers>
        <Trigger Property="ToggleButton.IsChecked" Value="True">
          <Setter Property="Control.Foreground" Value="Black"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="DioTabItemStyle" TargetType="{x:Type TabItem}">
      <Setter Property="Background" Value="#00808080"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Margin" Value="2,0,2,0"/>
      <Setter Property="BorderBrush" Value="#FFB8D8FC"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#FFB6D8FB"/>
          <Setter Property="Foreground" Value="Black"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </FrameworkElement.Resources>
    <Grid Margin="5,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="0.1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
    <Grid Row="2" ColumnSpan="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="0.5*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="0.5*"/>
        <ColumnDefinition Width="2*"/>
      </Grid.ColumnDefinitions>
      <Label Content="NO" Foreground="White" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center" FontWeight="Bold"/>
      <Grid Width="20" Height="20" Column="1" Row="0" ColumnSpan="1" HorizontalAlignment="Left">
        <Ellipse x:Name="lbl_State_A" Fill="Gray" Stroke="Black" StrokeThickness="1"/>
      </Grid>
      <Label Content="NC" Foreground="White" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center" FontWeight="Bold" Grid.Column="2"/>
      <Grid Width="20" Height="20" Column="3" Row="0" ColumnSpan="1" HorizontalAlignment="Left">
        <Ellipse x:Name="lbl_State_B" Fill="Gray" Stroke="Black" StrokeThickness="1"/>
        <Line x:Name="mask_DI" X1="0" Y1="10" X2="20" Y2="10" Stroke="Black" StrokeThickness="1"
              Visibility="Visible"/>
      </Grid>
      <ToggleButton Click="Btn_StatusDIO_Click" x:Name="Btn_StatusDIO" Content="DI STATE -&gt;" Background="#02000000"
                    BorderBrush="#FFB8D8FC" FontWeight="Bold" Grid.Row="0" Grid.Column="4" Margin="10,5,10,5">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
    </Grid>
    <Grid Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Border x:Name="border" Margin="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Grid.Row="0">
        <Label Content="{lx:Loc 지상반 I/O}" Margin="9,5,9,6" Foreground="White"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"
               RenderTransformOrigin="0.519,0.501" VerticalAlignment="Stretch"
               FontSize="16"/>
      </Border>
      <ToggleButton x:Name="Btn_SetDIO" Grid.Column="1" Content="SET" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Background="#02000000" BorderBrush="#FFB8D8FC" FontWeight="Bold"
                    Margin="5,5,5,5">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_OutTest" Grid.Column="2" Content="TEST" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Background="#02000000" BorderBrush="#FFB8D8FC" FontWeight="Bold"
                    Margin="5,5,5,5">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
    </Grid>
    <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="2" Margin="0,0,0,0" VerticalAlignment="Top"/>
    <Grid x:Name="Grid_Button" Row="1">
      <Grid.RowDefinitions>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="6*"/>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="6*"/>
        <ColumnDefinition Width="2*"/>
      </Grid.ColumnDefinitions>
      <Label x:Name="lbl_disableBtn" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="7" Grid.RowSpan="8"
             Panel.ZIndex="1"/>
      <Label FontWeight="Bold" Foreground="White" FontSize="17" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center" Grid.Column="0" Content="DI"/>
      <Label FontWeight="Bold" Foreground="White" FontSize="17" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Center" Grid.Column="3" Content="DO"/>
      <GridSplitter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="2" Grid.Column="2"
                    Grid.RowSpan="9"/>
    </Grid>
    <GridSplitter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="2" Grid.Column="1"
                  Grid.RowSpan="3"/>
    <Border x:Name="border2" Margin="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            Grid.Row="0" Grid.Column="2">
      <Grid>
        <Label x:Name="lbl_statusName" Content="{lx:Loc SRM I/O}" Margin="9,5,9,6" Foreground="White"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"
               RenderTransformOrigin="0.519,0.501" VerticalAlignment="Stretch"
               FontSize="16"/>
        <Label x:Name="lbl_ioSeq" Content="" Margin="9,5,9,6" Height="34" Foreground="White"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"
               RenderTransformOrigin="0.519,0.501" HorizontalAlignment="Right" VerticalAlignment="Stretch"
               FontSize="16"/>
      </Grid>
    </Border>
    <GridSplitter Grid.Row="1" Grid.Column="2" HorizontalAlignment="Stretch" Height="2" Margin="0,0,0,0"
                  VerticalAlignment="Top"/>
    <Grid x:Name="Grid_SrmIO" Row="1" Column="2" Margin="0,5,0,5" RowSpan="2" Background="#FF1F1F1F"
          Panel.ZIndex="2">
      <TabControl x:Name="TabSrmIoView" Background="#FF1F1F1F" BorderThickness="0"
                  SelectionChanged="TabSrmIoView_SelectionChanged">
        <TabControl.Resources>
          <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource DioTabItemStyle}"/>
        </TabControl.Resources>
        <TabItem Header="LIST">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="1*"/>
              <RowDefinition Height="9*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="5*"/>
              <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="lbl_Left" FontWeight="Bold" Foreground="White" FontSize="17"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Grid.Column="0"
                   Content="Left"/>
            <Label x:Name="lbl_Right" FontWeight="Bold" Foreground="White" FontSize="17"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Grid.Column="1"
                   Content="Right"/>
            <Grid x:Name="grid_SrmIO" Grid.Row="1" Grid.ColumnSpan="2">
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
            </Grid>
            <!-- LIST I/O 페이지만 덮음 — 탭헤더/3D MAP은 가로채지 않음 -->
            <Button Click="Btn_Right_Click" x:Name="Btn_Right" Content="&gt;" Grid.Row="1" Grid.ColumnSpan="2"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,5,0,0" FontSize="150"
                    FontWeight="Bold" Background="Transparent" Panel.ZIndex="1" Cursor="Hand">
              <FrameworkElement.Resources>
                <SolidColorBrush x:Key="HoverColor" Color="Transparent"/>
                <SolidColorBrush x:Key="NormalForeground" Color="#CC925555"/>
                <SolidColorBrush x:Key="HoverBackground" Color="Transparent"/>
                <Style TargetType="{x:Type Button}">
                  <Setter Property="Control.Foreground" Value="#7F925555"/>
                  <Setter Property="Control.Background" Value="{StaticResource HoverColor}"/>
                </Style>
              </FrameworkElement.Resources>
              <Control.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                  <Border Name="border" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                      <Setter Value="{StaticResource NormalForeground}" Property="Control.Foreground"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Control.Template>
            </Button>
          </Grid>
        </TabItem>
        <TabItem Header="3D MAP">
          <Grid x:Name="grid3dHost" Background="#FF1F1F1F"/>
        </TabItem>
      </TabControl>
    </Grid>
    <Grid x:Name="grid_StatusIO" Row="1" Column="2" RowSpan="3" ZIndex="-1" Background="#FF1F1F1F"
          Margin="0,5,0,5">
      <Grid.RowDefinitions>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
        <RowDefinition/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5*"/>
        <ColumnDefinition Width="3*"/>
        <ColumnDefinition Width="5*"/>
        <ColumnDefinition Width="3*"/>
      </Grid.ColumnDefinitions>
      <Label x:Name="lbl_disableStatusBtn" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="26" Grid.RowSpan="24"
             Panel.ZIndex="-1"/>
    </Grid>
  </Grid>
</Page>
