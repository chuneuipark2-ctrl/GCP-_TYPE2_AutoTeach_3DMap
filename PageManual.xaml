<Page x:Class="gcp_Wpf.PageManual"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      Title="PageManual" Foreground="#19000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="33*"/>
            <RowDefinition Height="33*"/>
            <RowDefinition Height="33*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="White" BorderThickness="1" CornerRadius="5,5,5,5" HorizontalAlignment="Stretch"
            Grid.Row="0">
            <Grid Margin="5,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="60*"/>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <!-- Row 0: 주행 | 현재위치 | 목적위치 | 정위치기준 | 좌 | 우 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lx:Loc 주행}" FontWeight="Bold"
                   Foreground="White" FontSize="20" Grid.Column="0"
                   Background="{x:Null}" VerticalContentAlignment="Center"/>
                    <Label x:Name="lbl_travCurPos" Content="0" Grid.Column="1" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FF90EE90" FontSize="16"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#33000000"
                   Visibility="Collapsed">
                        <Label.ToolTip>
                            <ToolTip Content="주행 현재 위치"/>
                        </Label.ToolTip>
                    </Label>
                    <Label x:Name="lbl_travTargetPos" Content="0" Grid.Column="2" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFFFA500" FontSize="16"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#33000000"
                   Visibility="Collapsed">
                        <Label.ToolTip>
                            <ToolTip Content="주행 목적 위치"/>
                        </Label.ToolTip>
                    </Label>
                    <Label Content="{lx:Loc 정위치기준}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
               FontWeight="Bold" Foreground="White" FontSize="18" HorizontalContentAlignment="Center"
                   Grid.Column="3" VerticalContentAlignment="Center"/>
                    <ToggleButton x:Name="Btn_StdLeft" Content="{lx:Loc 좌측}" FontSize="17" FontWeight="Bold" Background="#33FFFFFF"
                          BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="4"
                          BorderBrush="{x:Null}" Margin="5,0,0,0">
                        <FrameworkElement.Style>
                            <Style TargetType="{x:Type ToggleButton}">
                                <Setter Property="Control.Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                            BorderBrush="{TemplateBinding Control.BorderBrush}"
                            BorderThickness="{TemplateBinding Control.BorderThickness}"
                            Padding="{TemplateBinding Control.Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                        SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                                <Style.Triggers>
                                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                                        <Setter Property="Control.Foreground" Value="GreenYellow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </FrameworkElement.Style>
                    </ToggleButton>
                    <ToggleButton x:Name="Btn_StdRight" Content="{lx:Loc 우측}" FontSize="17" FontWeight="Bold" Background="#33FFFFFF"
                          BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="5"
                          BorderBrush="{x:Null}" Margin="5,0,0,0">
                        <FrameworkElement.Style>
                            <Style TargetType="{x:Type ToggleButton}">
                                <Setter Property="Control.Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                            BorderBrush="{TemplateBinding Control.BorderBrush}"
                            BorderThickness="{TemplateBinding Control.BorderThickness}"
                            Padding="{TemplateBinding Control.Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                        SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                                <Style.Triggers>
                                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                                        <Setter Property="Control.Foreground" Value="GreenYellow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </FrameworkElement.Style>
                    </ToggleButton>
                </Grid>
                <!-- Row 1: fastB, slowB, lbl_tarBbay, lbl_BMove, lbl_curBay, lbl_FMove, lbl_tarFbay, slowF, fastF -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="fastB" Stylus.IsPressAndHoldEnabled="False"
                    Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                Grid.Column="0" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/fastD.png" 
                 Stretch="Uniform" 
                 Width="65" Height="65"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastD.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastDP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="slowB" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                Grid.Column="2" BorderBrush="{x:Null}" Margin="0,0,10,0">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/slowD.png" StretchDirection="Both" Stretch="Fill"
                       Width="65" Height="65"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowD.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowDP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Label x:Name="lbl_tarBbay" Content="0" HorizontalAlignment="Center"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFADADAD" Width="57" FontSize="40"
                   HorizontalContentAlignment="Center" Height="106" VerticalContentAlignment="Center" Grid.Column="3"/>
                    <Label x:Name="lbl_BMove" HorizontalAlignment="Stretch" FontWeight="Bold"
                   Foreground="#FFADADAD" Width="30" FontSize="40" HorizontalContentAlignment="Center" Height="30"
                   VerticalContentAlignment="Center" Grid.Column="4">
                        <Control.Background>
                            <ImageBrush ImageSource="/Resources/moveLN.png"/>
                        </Control.Background>
                    </Label>
                    <Label x:Name="lbl_curBay" Content="0" HorizontalAlignment="Center"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="White" Width="114" FontSize="50"
                   HorizontalContentAlignment="Center" Height="106" VerticalContentAlignment="Center" Grid.Column="5"/>
                    <Label x:Name="lbl_FMove" HorizontalAlignment="Stretch" FontWeight="Bold"
                   Foreground="#FFADADAD" Width="30" FontSize="40" HorizontalContentAlignment="Center" Height="30"
                   VerticalContentAlignment="Center" Grid.Column="6">
                        <Control.Background>
                            <ImageBrush ImageSource="/Resources/moveRN.png"/>
                        </Control.Background>
                    </Label>
                    <Label x:Name="lbl_tarFbay" Content="0" HorizontalAlignment="Stretch" FontWeight="Bold"
                   Foreground="#FFADADAD" Width="57" FontSize="40" HorizontalContentAlignment="Center" Height="106"
                   VerticalContentAlignment="Center" Grid.Column="7"/>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="slowF" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                    Grid.Column="8" Margin="10,0,0,0" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/slowU.png" StretchDirection="Both" Stretch="Fill"
                       Width="65" Height="65"/>
                                    <TextBlock VerticalAlignment="Center" Foreground="White" HorizontalAlignment="Center" Width="65"
                           TextAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowU.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowUP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="fastF" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                    Grid.Column="10" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/fastU.png" StretchDirection="Both" Stretch="Fill"
                       Width="65" Height="65"/>
                                    <TextBlock VerticalAlignment="Center" Foreground="White" HorizontalAlignment="Center" Width="65"
                           TextAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastU.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastUP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                </Grid>
                <!-- Row 2-3: 후진, BAY, 전진 -->
                <Grid Grid.Row="2" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lx:Loc 후진}" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FF58B6C0" FontSize="20"
                   HorizontalContentAlignment="Center" Grid.Column="0" VerticalContentAlignment="Top"/>
                    <Label Content="BAY" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   FontWeight="Bold" Foreground="White" Width="86" FontSize="18" HorizontalContentAlignment="Center"
                   Grid.Column="4" VerticalContentAlignment="Top" Grid.ColumnSpan="2"/>
                    <Label Content="{lx:Loc 전진}" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FF58B6C0" FontSize="20"
                   HorizontalContentAlignment="Center" Grid.Column="9" VerticalContentAlignment="Top"/>
                </Grid>
            </Grid>
        </Border>
        <Border BorderBrush="White" BorderThickness="1" CornerRadius="5,5,5,5" HorizontalAlignment="Stretch"
            Grid.Row="1">
            <Grid Margin="5,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="60*"/>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <!-- Row 0: 승강 | 현재위치 | 목적위치 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lx:Loc 승강}" FontWeight="Bold"
                   Foreground="White" FontSize="20" Grid.Column="0"
                   Background="{x:Null}" VerticalContentAlignment="Center"/>
                    <Label x:Name="lbl_hoistCurPos" Content="0" Grid.Column="1" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FF90EE90" FontSize="16"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#33000000"
                   Visibility="Collapsed">
                        <Label.ToolTip>
                            <ToolTip Content="승강 현재 위치"/>
                        </Label.ToolTip>
                    </Label>
                    <Label x:Name="lbl_hoistTargetPos" Content="0" Grid.Column="2" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFFFA500" FontSize="16"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#33000000"
                   Visibility="Collapsed">
                        <Label.ToolTip>
                            <ToolTip Content="승강 목적 위치"/>
                        </Label.ToolTip>
                    </Label>
                </Grid>
                <!-- Row 1: fastD, slowD, lbl_tarDlev, lbl_DMove, lbl_curLev, lbl_UMove, lbl_tarUlev, slowU, fastU -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="fastD" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                Grid.Column="0" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/fastD.png" StretchDirection="Both" Stretch="Fill"
                       Width="65" Height="65"/>
                                    <TextBlock VerticalAlignment="Center" Foreground="White" HorizontalAlignment="Center" Width="65"
                           TextAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastD.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastDP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="slowD" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                Grid.Column="2" BorderBrush="{x:Null}" Margin="0,0,10,0">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/slowD.png" StretchDirection="Both" Stretch="Fill"
                       Width="65" Height="65"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowD.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowDP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Label x:Name="lbl_tarDlev" Content="0" HorizontalAlignment="Center"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFADADAD" Width="57" FontSize="40"
                   HorizontalContentAlignment="Center" Height="106" VerticalContentAlignment="Center" Grid.Column="3"/>
                    <Label x:Name="lbl_DMove" HorizontalAlignment="Stretch" FontWeight="Bold"
                   Foreground="#FFADADAD" Width="30" FontSize="40" HorizontalContentAlignment="Center" Height="30"
                   VerticalContentAlignment="Center" Grid.Column="4">
                        <Control.Background>
                            <ImageBrush ImageSource="/Resources/moveLN.png"/>
                        </Control.Background>
                    </Label>
                    <Border x:Name="lbl_top" Grid.Column="5" BorderBrush="#4CFFFFFF" BorderThickness="0,10,0,0"
                Margin="0,4,0,0" VerticalAlignment="Stretch"/>
                    <Border x:Name="lbl_bottom" Grid.Column="5" BorderBrush="#4CFFFFFF" BorderThickness="0,0,0,10"
                Margin="0,0,0,4" VerticalAlignment="Stretch"/>
                    <Label x:Name="lbl_curLev" Content="0" HorizontalAlignment="Center"
               VerticalAlignment="Stretch" FontWeight="Bold" Foreground="White" Width="114" FontSize="50"
                   HorizontalContentAlignment="Center" Height="106" VerticalContentAlignment="Center" Grid.Column="5"/>
                    <Label x:Name="lbl_UMove" HorizontalAlignment="Stretch" FontWeight="Bold"
               Foreground="#FFADADAD" Width="30" FontSize="40" HorizontalContentAlignment="Center" Height="30"
                   VerticalContentAlignment="Center" Grid.Column="6">
                        <Control.Background>
                            <ImageBrush ImageSource="/Resources/moveRN.png"/>
                        </Control.Background>
                    </Label>
                    <Label x:Name="lbl_tarUlev" Content="0" HorizontalAlignment="Stretch"
                   FontWeight="Bold" Foreground="#FFADADAD" Width="57" FontSize="40"
                   HorizontalContentAlignment="Center" Height="106" VerticalContentAlignment="Center" Grid.Column="7"/>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="slowU" Stylus.IsPressAndHoldEnabled="False"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="White"
                    Grid.Column="8" Margin="10,0,0,0" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/slowU.png" StretchDirection="Both" Stretch="Fill"
                           Width="65" Height="65"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowU.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/slowUP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                    <Button PreviewMouseDown="Button_PreviewMouseDown" PreviewMouseUp="Button_PreviewMouseUp" x:Name="fastU" Stylus.IsPressAndHoldEnabled="False"
                    Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Grid.Column="10" BorderBrush="{x:Null}">
                        <Control.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid Background="Transparent">
                                    <Image x:Name="buttonImage" Source="/Resources/fastU.png" StretchDirection="Both" Stretch="Fill"
                           Width="65" Height="65"/>
                                    <TextBlock VerticalAlignment="Center" Foreground="White" HorizontalAlignment="Center" Width="65"
                               TextAlignment="Center"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ButtonBase.IsPressed" Value="False">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastU.png"/>
                                    </Trigger>
                                    <Trigger Property="ButtonBase.IsPressed" Value="True">
                                        <Setter TargetName="buttonImage" Property="Image.Source" Value="/Resources/fastUP.png"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Control.Template>
                    </Button>
                </Grid>
                <!-- Row 2-3: 하강, LEV, 상승 -->
                <Grid Grid.Row="2" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.3*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lx:Loc 하강}" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFCC8B8B" FontSize="20"
                   HorizontalContentAlignment="Center" Grid.Column="0" VerticalContentAlignment="Top"/>
                    <Label Content="LEV" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   FontWeight="Bold" Foreground="White" Width="86" FontSize="18" HorizontalContentAlignment="Center"
                   Grid.Column="4" VerticalContentAlignment="Top" Grid.ColumnSpan="2"/>
                    <Label Content="{lx:Loc 상승}" HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" FontWeight="Bold" Foreground="#FFCC8B8B" FontSize="20"
                   HorizontalContentAlignment="Center" Grid.Column="9" VerticalContentAlignment="Top"/>
                </Grid>
            </Grid>
        </Border>
        <Border BorderBrush="White" BorderThickness="1" CornerRadius="5,5,5,5" HorizontalAlignment="Stretch"
            Grid.Row="2">
            <Grid x:Name="gridFork" Margin="5,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="60*"/>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <!-- Row 0: 포크1/포크2, HALF/FULL 버튼 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lx:Loc 포크}" FontWeight="Bold"
                   Foreground="White" FontSize="20" Grid.Column="0"
                   Background="{x:Null}" VerticalContentAlignment="Center"/>
                    <ToggleButton x:Name="Btn_Fork1" Content="{lx:Loc 포크1}" FontSize="17" FontWeight="Bold" Background="#33FFFFFF"
                      BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="2"
                          Grid.ColumnSpan="1" BorderBrush="{x:Null}" Margin="0,5,5,5">
                        <FrameworkElement.Style>
                            <Style TargetType="{x:Type ToggleButton}">
                                <Setter Property="Control.Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                            BorderBrush="{TemplateBinding Control.BorderBrush}"
                            BorderThickness="{TemplateBinding Control.BorderThickness}"
                            Padding="{TemplateBinding Control.Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                        SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                                <Style.Triggers>
                                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                                        <Setter Property="Control.Foreground" Value="GreenYellow"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </FrameworkElement.Style>
                    </ToggleButton>
