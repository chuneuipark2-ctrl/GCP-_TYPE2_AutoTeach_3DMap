<Page x:Class="gcp_Wpf.PageMonitorFromWCS"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gcp_Wpf"
      Title="PageMonitorFromWCS">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="10*"/>
      <RowDefinition Height="90*"/>
    </Grid.RowDefinitions>
    <Label x:Name="lbl_PageInfo" Content="" Margin="0,0,10,0" Foreground="White" FontSize="14"
           FontWeight="Bold" HorizontalAlignment="Right" VerticalContentAlignment="Center"
           HorizontalContentAlignment="Center"/>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5*"/>
        <ColumnDefinition Width="5*"/>
      </Grid.ColumnDefinitions>
      <Label Content="PLC -&gt; WCS" Height="34" Foreground="White" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Stretch" FontWeight="Bold" VerticalAlignment="Stretch" FontSize="16"/>
      <Label Content="WCS -&gt; PLC" Height="34" Foreground="White" HorizontalContentAlignment="Center"
             VerticalContentAlignment="Stretch" FontWeight="Bold" VerticalAlignment="Stretch" FontSize="16"
             Grid.Column="1"/>
    </Grid>
    <Grid Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="9*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="9*"/>
      </Grid.ColumnDefinitions>
    </Grid>
    <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Height="2" Margin="0,0,0,0" VerticalAlignment="Top"/>
    <Grid Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="9*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="9*"/>
      </Grid.ColumnDefinitions>
      <Grid x:Name="dataLeft" Column="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*"/>
          <ColumnDefinition Width="0.8*"/>
          <ColumnDefinition Width="8*"/>
          <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
      </Grid>
      <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="2" Margin="0,0,0,0"
                    VerticalAlignment="Stretch"/>
      <Grid x:Name="dataRight" Column="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*"/>
          <ColumnDefinition Width="0.8*"/>
          <ColumnDefinition Width="8*"/>
          <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
      </Grid>
      <Button x:Name="Btn_Left" Content="&lt;" Grid.Column="0" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" Margin="0,5,0,0" FontSize="150" FontWeight="Bold">
        <FrameworkElement.Resources>
          <SolidColorBrush x:Key="HoverColor" Color="Transparent"/>
          <SolidColorBrush x:Key="NormalForeground" Color="#CC925555"/>
          <SolidColorBrush x:Key="HoverBackground" Color="Transparent"/>
          <ImageBrush x:Key="BackgroundImage" ImageSource="/Resources/slowL.png">
            <TileBrush.Viewport>
              <Rect>
                0.25, 0.25, 0.5, 0.5
              </Rect>
            </TileBrush.Viewport>
            <TileBrush.Viewbox>
              <Rect>0, 0, 1, 1</Rect>
            </TileBrush.Viewbox>
          </ImageBrush>
          <Style TargetType="{x:Type Button}">
            <Setter Property="Control.Foreground" Value="#7F925555"/>
            <Setter Property="Control.Background" Value="{StaticResource HoverColor}"/>
          </Style>
        </FrameworkElement.Resources>
        <Control.Template>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Name="border" Background="{TemplateBinding Control.Background}"
                    BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}"
                    Padding="{TemplateBinding Control.Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="ButtonBase.IsPressed" Value="True">
                <Setter Value="{StaticResource NormalForeground}" Property="Control.Foreground"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Control.Template>
      </Button>
      <Button x:Name="Btn_Right" Content="&gt;" Grid.Column="2" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" Margin="0,5,0,0" FontSize="150" FontWeight="Bold">
        <FrameworkElement.Resources>
          <SolidColorBrush x:Key="HoverColor" Color="Transparent"/>
          <SolidColorBrush x:Key="NormalForeground" Color="#CC925555"/>
          <SolidColorBrush x:Key="HoverBackground" Color="Transparent"/>
          <Style TargetType="{x:Type Button}">
            <Setter Property="Control.Foreground" Value="#7F925555"/>
            <Setter Property="Control.Background" Value="{StaticResource HoverBackground}"/>
          </Style>
        </FrameworkElement.Resources>
        <Control.Template>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Name="border" Background="{TemplateBinding Control.Background}"
                    BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}"
                    Padding="{TemplateBinding Control.Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="ButtonBase.IsPressed" Value="True">
                <Setter Value="{StaticResource NormalForeground}" Property="Control.Foreground"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Control.Template>
      </Button>
    </Grid>
  </Grid>
</Page>