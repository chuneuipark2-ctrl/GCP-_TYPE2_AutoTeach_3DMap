<Page x:Class="gcp_Wpf.PageMonitorSRM"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      Title="PageMonitorSRM">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="10*"/>
      <RowDefinition Height="1*"/>
      <RowDefinition Height="90*"/>
    </Grid.RowDefinitions>
    <Grid Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="4*"/>
        <ColumnDefinition Width="1.1*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1.3*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>
      <Border x:Name="border" Margin="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Grid.Row="0" Grid.Column="0">
        <Label Content="{lx:Loc SRM 상태 정보    TYPE / VALUE}" Margin="9,5,9,6" Height="34" Foreground="White"
               HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold"
               RenderTransformOrigin="0.519,0.501" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
               FontSize="16"/>
      </Border>
      <Label x:Name="lbl_PageInfo" Content="1 / 8" Grid.ColumnSpan="1" Foreground="White" FontSize="14"
             FontWeight="Bold" Margin="0,0,10,0" Grid.Column="7" HorizontalAlignment="Right"
             VerticalAlignment="Center"/>
      <ToggleButton x:Name="Btn_LfTr" Content="{lx:Loc 주행/승강}" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="1"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_Fork1" Content="{lx:Loc 포크1}" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="2"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_Fork2" Content="{lx:Loc 포크2}" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="3"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_SP1" Content="{lx:Loc 포크1/2 작업}" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="4"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_SP2" Content="Ext1" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="5"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
      <ToggleButton x:Name="Btn_SP3" Content="Ext2" FontSize="14" FontWeight="Bold" Background="#02000000"
                    BorderThickness="1,1,1,1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="6"
                    BorderBrush="{x:Null}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                      <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
            <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Setter Property="Control.Foreground" Value="Black"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
    </Grid>
    <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="2" Margin="0,0,0,0" VerticalAlignment="Top"/>
    <Grid x:Name="dataGrid" Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="9*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="9*"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="9*"/>
      </Grid.ColumnDefinitions>
      <Grid x:Name="dataLeft" Column="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="7*"/>
          <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
      </Grid>
      <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="2" Margin="0,0,0,0"
                    VerticalAlignment="Stretch"/>
      <Grid x:Name="dataCenter" Column="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="8*"/>
          <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
      </Grid>
      <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Width="2" Margin="0,0,0,0"
                    VerticalAlignment="Stretch"/>
      <Grid x:Name="dataRight" Column="4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="8*"/>
          <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
          <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
      </Grid>
      <Button x:Name="Btn_Left" Content="&lt;" Grid.Column="2" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" Margin="0,5,0,0" FontSize="150" FontWeight="Bold">
        <FrameworkElement.Resources>
          <SolidColorBrush x:Key="HoverColor" Color="Transparent"/>
          <SolidColorBrush x:Key="NormalForeground" Color="#CC925555"/>
          <SolidColorBrush x:Key="HoverBackground" Color="Transparent"/>
          <ImageBrush x:Key="BackgroundImage" ImageSource="/Resources/slowL.png">
            <TileBrush.Viewport>
              <Rect>
                0.25, 0.25, 0.5, 0.5
              </Rect>
            </TileBrush.Viewport>
            <TileBrush.Viewbox>
              <Rect>0, 0, 1, 1</Rect>
            </TileBrush.Viewbox>
          </ImageBrush>
          <Style TargetType="{x:Type Button}">
            <Setter Property="Control.Foreground" Value="#7F925555"/>
            <Setter Property="Control.Background" Value="{StaticResource HoverColor}"/>
          </Style>
        </FrameworkElement.Resources>
        <Control.Template>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Name="border" Background="{TemplateBinding Control.Background}"
                    BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}"
                    Padding="{TemplateBinding Control.Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="ButtonBase.IsPressed" Value="True">
                <Setter Value="{StaticResource NormalForeground}" Property="Control.Foreground"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Control.Template>
      </Button>
      <Button x:Name="Btn_Right" Content="&gt;" Grid.Column="4" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" Margin="0,5,0,0" FontSize="150" FontWeight="Bold">
        <FrameworkElement.Resources>
          <SolidColorBrush x:Key="HoverColor" Color="Transparent"/>
          <SolidColorBrush x:Key="NormalForeground" Color="#CC925555"/>
          <SolidColorBrush x:Key="HoverBackground" Color="Transparent"/>
          <Style TargetType="{x:Type Button}">
            <Setter Property="Control.Foreground" Value="#7F925555"/>
            <Setter Property="Control.Background" Value="{StaticResource HoverBackground}"/>
          </Style>
        </FrameworkElement.Resources>
        <Control.Template>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Name="border" Background="{TemplateBinding Control.Background}"
                    BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}"
                    Padding="{TemplateBinding Control.Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="ButtonBase.IsPressed" Value="True">
                <Setter Value="{StaticResource NormalForeground}" Property="Control.Foreground"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Control.Template>
      </Button>
    </Grid>
  </Grid>
</Page>