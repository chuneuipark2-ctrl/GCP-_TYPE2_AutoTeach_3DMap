                        <Style.Triggers>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter Property="Control.Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </FrameworkElement.Style>
            </ToggleButton>
            <ToggleButton Click="Btn_CommandClick" x:Name="Btn_DestRackChange" Grid.Row="1" Grid.Column="6"
                    Content="{lx:Loc 목적지 랙 변경}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#02000000"
                    BorderBrush="#FFB8D8FC" FontWeight="Bold" Margin="5,5,5,5" FontSize="14">
                <FrameworkElement.Style>
                    <Style TargetType="{x:Type ToggleButton}">
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ToggleButton.IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                        <Style.Triggers>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter Property="Control.Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </FrameworkElement.Style>
            </ToggleButton>
            <ToggleButton Click="Btn_CommandClick" x:Name="Btn_DestStationChange" Grid.Row="1" Grid.Column="7"
                    Content="{lx:Loc 목적지 스테이션 변경}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="#02000000" BorderBrush="#FFB8D8FC" FontWeight="Bold" Margin="5,5,5,5" FontSize="14">
                <FrameworkElement.Style>
                    <Style TargetType="{x:Type ToggleButton}">
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ToggleButton.IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                        <Style.Triggers>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter Property="Control.Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </FrameworkElement.Style>
            </ToggleButton>
        </Grid>
        <Grid Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="45*"/>
                <RowDefinition Height="45*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="White" BorderThickness="0,0,0,2" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                    <Label Content="{lx:Loc 작업 명}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White"
                 HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="14"/>
                </Border>
                <Label Content="{lx:Loc PLC인터록무시}" Grid.Row="9" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501" Height="34"/>
                <Label Content="{lx:Loc 공출고/공입고 무시}" Grid.Row="10" Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501" Height="34"/>
                <ToggleButton x:Name="Btn_IgnoreCV" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="18" FontWeight="Bold" Background="#02000000" BorderBrush="{x:Null}" BorderThickness="1,1,1,1" Grid.Column="3" Grid.Row="9" Checked="Btn_IgnoreCV_Checked" Unchecked="Btn_IgnoreCV_Unchecked">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Content" Value="OFF"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="border" CornerRadius ="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FFB6D8FB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#7FC8C8C8"/>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Content" Value="ON"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
                <ToggleButton x:Name="Btn_IgnoreGoods" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="18" FontWeight="Bold" Background="#02000000" BorderBrush="{x:Null}" BorderThickness="1,1,1,1" Grid.Column="5" Grid.Row="10" Checked="Btn_IgnoreGoods_Checked" Unchecked="Btn_IgnoreGoods_Unchecked">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Content" Value="OFF"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="border" CornerRadius ="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FFB6D8FB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#7FC8C8C8"/>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="Content" Value="ON"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>
            <Border x:Name="Bdr_Fork1" Grid.Row="1" BorderThickness="1" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" CornerRadius="5,5,5,5" Background="#CC2B2D33" BorderBrush="White"
              Margin="10,10,10,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="40*"/>
                        <RowDefinition Height="40*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="Btn_Fork1Sel"
                        Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                        Margin="10"
                        BorderThickness="1"
                        FontWeight="Bold"
                        FontSize="20"
                        Foreground="#FF686868"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Cursor="Hand"
                        Click="Btn_Fork1Sel_Click" Background="Transparent" BorderBrush="#FF757575">

                        <!-- 다국어 변환 유지 -->
                        <TextBlock Text="{lx:Loc 포크1 작업}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
CornerRadius="6"
Background="{TemplateBinding Background}"
BorderBrush="{TemplateBinding BorderBrush}"
BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center"
              VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Hover 효과 -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="GreenYellow"/>
                                    </Trigger>

                                    <!-- Disable 상태 -->
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#FF686868"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Label x:Name="lbl_fromStr" Grid.Column="1" Grid.Row="1" Content="From" HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <Label x:Name="lbl_toStr" Grid.Column="1" Grid.Row="2" Content="To" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                 FontWeight="Bold" FontSize="14"/>
                    <Label Grid.Column="2" Grid.Row="0" Content="Stn" HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501"
                 FontSize="14"/>
                    <Label Grid.Column="3" Grid.Row="0" Content="Row" HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501"
                 FontSize="14"/>
                    <Label Grid.Column="4" Grid.Row="0" Content="Bay" HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501"
                 FontSize="14"/>
                    <Label Grid.Column="5" Grid.Row="0" Content="Lev" HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center" FontWeight="Bold" RenderTransformOrigin="0.519,0.501"
                 FontSize="14"/>
                    <TextBox PreviewMouseDown="Btn_FromTo_Select" x:Name="Edit_Fk1FromStn" HorizontalAlignment="Stretch"
                   TextWrapping="Wrap" Text="0" TextAlignment="Center" HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center" FontSize="20" Foreground="White" VerticalAlignment="Stretch"
                   IsEnabled="False" CaretBrush="#00000000" Grid.Column="2" Grid.Row="1" Margin="20,10,20,10"
                   Background="{x:Null}">
                        <FrameworkElement.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Border.CornerRadius" Value="3"/>
                            </Style>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Control.BorderBrush" Value="#FFB8D8FC"/>
                                <Setter Property="Control.BorderThickness" Value="2"/>
                                <Style.Triggers>
                                    <Trigger Property="UIElement.IsEnabled" Value="True">
                                        <Setter Property="Control.BorderBrush" Value="#FF22B9AF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </FrameworkElement.Resources>
                    </TextBox>
                    <TextBox PreviewMouseDown="Btn_FromTo_Select" x:Name="Edit_Fk1FromRow" HorizontalAlignment="Stretch"
                   Margin="20,10,20,10" TextWrapping="Wrap" Text="0" TextAlignment="Center"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="20"
                   Foreground="White" VerticalAlignment="Stretch" IsEnabled="False" CaretBrush="#00000000"
                   Grid.Column="3" Grid.Row="1" BorderThickness="2,2,2,2" Background="{x:Null}">
                        <FrameworkElement.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Border.CornerRadius" Value="3"/>
                            </Style>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Control.BorderBrush" Value="#FFB8D8FC"/>
                                <Style.Triggers>
                                    <Trigger Property="UIElement.IsEnabled" Value="True">
                                        <Setter Property="Control.BorderBrush" Value="#FF22B9AF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </FrameworkElement.Resources>
                    </TextBox>
                    <TextBox PreviewMouseDown="Btn_FromTo_Select" x:Name="Edit_Fk1FromBay" HorizontalAlignment="Stretch"
                   Margin="20,10,20,10" TextWrapping="Wrap" Text="0" VerticalAlignment="Stretch"
                   TextAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                   FontSize="20" Foreground="White" IsEnabled="False" CaretBrush="#00000000" Grid.Column="4"
                   Grid.Row="1" BorderThickness="2,2,2,2" Background="{x:Null}">
                        <FrameworkElement.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Border.CornerRadius" Value="3"/>
                            </Style>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Control.BorderBrush" Value="#FFB8D8FC"/>
                                <Style.Triggers>
                                    <Trigger Property="UIElement.IsEnabled" Value="True">
