      xmlns:local="clr-namespace:gcp_Wpf"
      xmlns:lx="clr-namespace:gcp_Wpf"
      mc:Ignorable="d" 
      Title="PageSemiAuto">
    <Grid>
        <!-- (2026-07-08) 오토티칭 정보 스트립 제거 — 반자동 그리드가 전체 화면 사용 -->
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Grid Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="15*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="White" BorderThickness="0,0,0,2" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
                <Label Content="{lx:Loc 작업선택}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White"
               HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="14"/>
            </Border>
            <ToggleButton Click="Btn_CommandClick" x:Name="Btn_Move" Grid.Row="1" Grid.Column="0" Content="{lx:Loc 이동}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#02000000"
                    BorderBrush="#FFB8D8FC" FontWeight="Bold" Margin="5,5,5,5" FontSize="14">
                <FrameworkElement.Style>
                    <Style TargetType="{x:Type ToggleButton}">
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ToggleButton.IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Border.Background" Value="#FFB6D8FB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Control.Foreground" Value="#7FC8C8C8"/>
                        <Style.Triggers>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter Property="Control.Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </FrameworkElement.Style>
            </ToggleButton>
            <ToggleButton Click="Btn_CommandClick" x:Name="Btn_Store" Grid.Row="1" Grid.Column="1" Content="{lx:Loc 입고}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#02000000"
                    BorderBrush="#FFB8D8FC" FontWeight="Bold" Margin="5,5,5,5" FontSize="14">
                <FrameworkElement.Style>
                    <Style TargetType="{x:Type ToggleButton}">
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="border" CornerRadius="15" Background="{TemplateBinding Control.Background}"
                          BorderBrush="{TemplateBinding Control.BorderBrush}"
                          BorderThickness="{TemplateBinding Control.BorderThickness}"
                          Padding="{TemplateBinding Control.Padding}">
